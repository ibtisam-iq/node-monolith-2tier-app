# =============================================================
# .dockerignore — node-monolith-2tier-app
# Build context = repo root (used by Dockerfile via compose.yml)
# =============================================================

# ── Version control ──────────────────────────────────────────
.git
.gitignore
.gitattributes
.gitmodules

# ── Environment & secrets ────────────────────────────────────
# Never send real credentials into the build context
.env
.env.*
!.env.example            # Exception: allow the example template (no real secrets)

# ── Documentation & assets (not needed in any image) ─────────
README.md
docs/
assets/
.scratchpad/

# ── node_modules (never send — always installed inside image) ─
# Dockerfile Stage 1: runs `npm install` from client/package.json
# Dockerfile Stage 2: runs `npm install --omit=dev` from server/package.json
# Sending node_modules defeats layer caching and bloats context
client/node_modules/
server/node_modules/

# ── Docker files themselves ───────────────────────────────────
# Not needed inside any container at runtime
Dockerfile
compose.yml
.dockerignore

# ── IDE and editor files ───────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# ── Test and coverage reports ──────────────────────────────────
*.log
  
